{
  "rubric_id": "bdr_qa_rubric_v1",
  "rubric_name": "BDR QA Rubric",
  "version": "1.0",
  "description": "Rubric used to evaluate BDR roleplay performance in the Leon B2B Simulator.",
  "scoring_scale": {
