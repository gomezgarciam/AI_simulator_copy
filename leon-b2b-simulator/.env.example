# AI Sales Simulator - Environment Configuration Example
# Instructions: Copy this file to .env and fill in the values below.

# Google Cloud Project Details
GOOGLE_CLOUD_PROJECT=your-project-id-here
GOOGLE_CLOUD_LOCATION=us-central1

# Model Selection
MODEL_ID=gemini-2.5-flash

# Storage & RAG Details
INTERNAL_DOCS_BUCKET=your-bucket-name-here
INTERNAL_DOCS_PREFIX=Plays/

# Advanced Configuration (Optional)
ASSISTANT_TOP_K=4
ROLEPLAY_HISTORY_MAX_TURNS=12
PDF_SUMMARY_THRESHOLD=15000
